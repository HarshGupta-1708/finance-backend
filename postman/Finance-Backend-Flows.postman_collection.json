{
  "info": {
    "name": "Finance Backend - Module Flows",
    "_postman_id": "11e2d12f-4ffb-4e8c-9f17-2a7cf9b7fb01",
    "description": "Flow-wise collection for Auth, Categories, Users, Records, and Dashboard modules.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const runId = pm.collectionVariables.get('runId') || Date.now().toString();",
          "pm.collectionVariables.set('runId', runId);",
          "if (!pm.collectionVariables.get('viewerEmail')) pm.collectionVariables.set('viewerEmail', `viewer.${runId}@finance.com`);",
          "if (!pm.collectionVariables.get('viewerPassword')) pm.collectionVariables.set('viewerPassword', 'viewer@1234');",
          "if (!pm.collectionVariables.get('viewerName')) pm.collectionVariables.set('viewerName', 'Viewer User');",
          "if (!pm.collectionVariables.get('recordDate')) pm.collectionVariables.set('recordDate', new Date().toISOString().slice(0, 10));",
          "if (!pm.collectionVariables.get('currentYear')) pm.collectionVariables.set('currentYear', String(new Date().getFullYear()));",
          "if (!pm.collectionVariables.get('seedViewerEmail')) pm.collectionVariables.set('seedViewerEmail', 'viewer@finance.com');",
          "if (!pm.collectionVariables.get('seedViewerPassword')) pm.collectionVariables.set('seedViewerPassword', 'viewer@1234');",
          "if (!pm.collectionVariables.get('adminCreatedUserEmail')) pm.collectionVariables.set('adminCreatedUserEmail', `admin.created.${runId}@finance.com`);",
          "if (!pm.collectionVariables.get('adminCreatedUserPassword')) pm.collectionVariables.set('adminCreatedUserPassword', 'created@1234');"
        ]
      }
    }
  ],
