    {
      "name": "1. Categories Flow",
      "description": "Resolve seeded category ids for later record operations.",
      "item": [
        {
          "name": "List All Active Categories",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{analystToken}}"
              }
            ],
            "url": "{{baseUrl}}/api/categories"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () { pm.response.to.have.status(200); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Resolve Income Category",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{analystToken}}"
              }
            ],
            "url": "{{baseUrl}}/api/categories?type=INCOME"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
                  "const categories = pm.response.json().data || [];",
                  "const target = categories.find((item) => item.name === 'Salary') || categories[0];",
                  "if (target?.id) pm.collectionVariables.set('incomeCategoryId', String(target.id));"
                ]
              }
            }
          ]
        },
        {
          "name": "Resolve Expense Category",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{analystToken}}"
              }
            ],
            "url": "{{baseUrl}}/api/categories?type=EXPENSE"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
                  "const categories = pm.response.json().data || [];",
                  "const target = categories.find((item) => item.name === 'Rent') || categories.find((item) => item.name === 'Food') || categories[0];",
                  "if (target?.id) pm.collectionVariables.set('expenseCategoryId', String(target.id));"
                ]
              }
            }
          ]
        }
      ]
    },
