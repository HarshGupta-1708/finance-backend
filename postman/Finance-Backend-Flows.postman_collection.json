  "item": [
    {
      "name": "0. Auth Flow",
      "description": "Register a viewer, login, verify /me, then get admin and analyst tokens.",
      "item": [
        {
          "name": "Register Viewer",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{viewerName}}\",\n  \"email\": \"{{viewerEmail}}\",\n  \"password\": \"{{viewerPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/register"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 201 or 409', function () { pm.expect([201,409]).to.include(pm.response.code); });",
                  "const json = pm.response.json();",
                  "if (pm.response.code === 201 && json?.data?.token) pm.collectionVariables.set('viewerToken', json.data.token);",
                  "if (json?.data?.user?.id) pm.collectionVariables.set('viewerUserId', json.data.user.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Login Viewer",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{viewerEmail}}\",\n  \"password\": \"{{viewerPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('viewerToken', json.data.token);",
                  "if (json?.data?.user?.id) pm.collectionVariables.set('viewerUserId', json.data.user.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Get My Profile (Viewer)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{viewerToken}}"
              }
            ],
            "url": "{{baseUrl}}/api/auth/me"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "if (json?.data?.id) pm.collectionVariables.set('viewerUserId', json.data.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Login Seeded Admin",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('adminToken', json.data.token);"
                ]
              }
            }
          ]
        },
        {
          "name": "Login Seeded Analyst",
          "request": {
            "method": "POST",
